{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "group:monorepos",
        "group:recommended"
    ],
    "enabledManagers": [
        "maven"
    ],
    "dependencyDashboard": true,
    "rangeStrategy": "bump",
    "ignorePaths": [
    ],
    "prConcurrentLimit": 10,
    "prHourlyLimit": 5,
    "packageRules": [
        {
            "description": "Group all major updates into a single monthly PR",
            "matchUpdateTypes": ["major"],
            "groupName": "all major dependencies",
            "schedule": ["on the first day of the month"]
        }
    ]
}
